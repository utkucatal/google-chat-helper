{
  "manifest_version": 3,
  "name": "Google Chat Helper",
  "version": "1.0.0",
  "description": "Enhance your Google Chat experience with useful features",
  "permissions": ["storage"],
  "options_page": "options.html",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Google Chat Helper"
  },
  "content_scripts": [
    {
      "matches": [
        "https://mail.google.com/chat/*",
        "https://chat.google.com/*",
        "https://mail.google.com/*",
        "https://chat.google.com/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_end",
      "all_frames": true
    }
  ]
}
